# PostgreSQL connection string (direct, no Supabase wrapper)
DATABASE_URL=postgresql://user:password@host:5432/database

# Comma-separated API server URLs
API_URLS=http://server1:3000,http://server2:3000

# Total concurrency across all API endpoints (default: 400)
TOTAL_CONCURRENCY=400

# Jobs to claim per poll cycle (default: 150)
BATCH_SIZE=150

# API request timeout in ms (default: 130000 — slightly above the API's 120s scrape timeout)
API_TIMEOUT_MS=130000

# How often to poll for new jobs in ms (default: 5000)
POLL_INTERVAL_MS=5000

# Max backoff when queue is empty in ms (default: 60000)
MAX_BACKOFF_MS=60000
