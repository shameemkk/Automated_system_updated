# --- Postgres (direct connection, no PostgREST) ---
# Use port 5432 (direct) for full feature support; 6543 (pgbouncer) also works for plain queries.
DATABASE_URL=postgres://postgres:PASSWORD@db.YOURPROJECT.supabase.co:5432/postgres
PG_POOL_MAX=20
PG_SSL=true

# --- HTTP API targets ---
# Comma-separated list of API instances (each running the service documented in api.md).
# api.md says one service instance supports ~100 in-flight globally
# (HTTP_MAX_CONCURRENCY=10 x NUM_WORKERS=10 cluster). With MAX_CONCURRENCY=150 below, you SHOULD run
# 2+ API instances or accept that ~50 requests will queue inside the API event loop.
HTTP_API_URLS=http://localhost:3000
# HTTP_API_URL=http://localhost:3000

# Ping GET /health on each target at startup (warn-only)
API_HEALTH_CHECK_AT_STARTUP=true

# --- Timeouts ---
# Per-request timeout. MUST exceed the API's OVERALL_TIMEOUT_MS (default 120s).
# Worker refuses to start below 30s; warns below 125s.
REQUEST_TIMEOUT_MS=130000

# --- Target cooldown (per-target health) ---
COOLDOWN_AFTER=3
COOLDOWN_MS=30000

# --- Client-side retry (per-job, applied inside api-client.ts) ---
API_MAX_RETRIES=2
API_RETRY_BACKOFF_BASE_MS=500
API_RATE_LIMIT_BACKOFF_BASE_MS=5000

# --- Worker concurrency & back-pressure ---
MAX_CONCURRENCY=150
CLAIM_BATCH_MAX=50
MAX_PENDING_UPDATES=2000
RESUME_THRESHOLD=1000

# --- Batch DB updates ---
BATCH_FLUSH_SIZE=50
BATCH_FLUSH_INTERVAL_MS=5000
BATCH_MAX_FLUSH_RETRIES=3

# --- Shutdown ---
SHUTDOWN_GRACE_MS=30000

# --- Watchdog (only the leader runs these; advisory-lock elected) ---
WATCHDOG_LOCK_KEY=8472345
STUCK_AFTER_MINUTES=10
WATCHDOG_INTERVAL_MS=60000
DIAG_INTERVAL_MS=300000
WATCHDOG_REACQUIRE_MS=30000
STALE_AGE_WARN_SECONDS=3600

# --- Observability ---
STATS_LOG_INTERVAL_MS=30000
DEBUG=false
