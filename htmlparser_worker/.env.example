# --- Postgres (direct connection, no PostgREST) ---
# Use port 5432 (direct) for full feature support; port 6543 (pgbouncer) also works for plain queries.
DATABASE_URL=postgres://postgres:PASSWORD@db.YOURPROJECT.supabase.co:5432/postgres
PG_POOL_MAX=10

# --- htmlparser load balancer ---
# Comma-separated list of htmlparser instances. Falls back to HTMLPARSER_URL if unset.
HTMLPARSER_URLS=http://localhost:3000,http://localhost:3001,http://localhost:3002
# HTMLPARSER_URL=http://localhost:3000

# Per-request hard timeout (axios + AbortController kill switch)
HTMLPARSER_TIMEOUT_MS=150000

# After this many consecutive failures, a target is parked for HTMLPARSER_COOLDOWN_MS
HTMLPARSER_COOLDOWN_AFTER=3
HTMLPARSER_COOLDOWN_MS=30000

# --- Worker ---
MAX_CONCURRENCY=50
BATCH_FLUSH_SIZE=25
BATCH_FLUSH_INTERVAL_MS=10000

# --- Watchdog (only the leader runs these; advisory-lock elected) ---
STUCK_AFTER_MINUTES=10
WATCHDOG_INTERVAL_MS=60000
DIAG_INTERVAL_MS=300000

# Optional
DEBUG=false
